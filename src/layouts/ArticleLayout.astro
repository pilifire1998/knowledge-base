---
import BaseLayout from './BaseLayout.astro';
import TableOfContents from '../components/TableOfContents';
import ReadingProgress from '../components/ReadingProgress';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  tags: string[];
  readingTime?: number;
}

const { title, description, pubDate, tags, readingTime = 5 } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <ReadingProgress client:load />

  <article class="min-h-screen">
    <!-- Article Header - Full Width -->
    <header class="border-b border-[var(--color-border)] bg-[var(--color-surface)]">
      <div class="container py-12 lg:py-16">
        <div class="max-w-4xl">
          <div class="flex flex-wrap gap-3 mb-6">
            {tags.map((tag) => (
              <span class="text-caption uppercase tracking-wider text-secondary px-2 py-1 border border-[var(--color-border)]">
                {tag}
              </span>
            ))}
          </div>
          <h1 class="text-display text-primary mb-6">{title}</h1>
          <p class="text-xl text-secondary mb-6 max-w-2xl">{description}</p>
          <div class="flex items-center gap-6 text-caption text-muted">
            <span>{pubDate.toLocaleDateString('zh-CN')}</span>
            <span>·</span>
            <span>{readingTime} 分钟阅读</span>
          </div>
        </div>
      </div>
    </header>

    <!-- Article Content - With TOC Sidebar -->
    <div class="container py-12 lg:py-16">
      <div class="lg:grid lg:grid-cols-[1fr_280px] lg:gap-16 lg:max-w-6xl lg:mx-auto">
        <!-- Main Content -->
        <div class="prose min-w-0 max-w-none">
          <slot />
        </div>

        <!-- Sidebar -->
        <aside class="hidden lg:block">
          <div class="sticky top-24">
            <TableOfContents client:load />
          </div>
        </aside>
      </div>
    </div>
  </article>

  <!-- Article Footer -->
  <footer class="border-t border-[var(--color-border)] py-8 bg-[var(--color-bg)]">
    <div class="container">
      <div class="max-w-4xl flex items-center justify-between">
        <a href="/articles" class="text-sm text-secondary hover:text-primary transition-colors">
          ← 返回文章列表
        </a>
        <div class="flex items-center gap-4 text-muted text-sm">
          <button class="hover:text-primary transition-colors">分享</button>
        </div>
      </div>
    </div>
  </footer>
</BaseLayout>
