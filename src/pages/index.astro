---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const articles = await getCollection('articles');
const sortedArticles = articles
  .filter((a) => !a.data.draft)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 6);
---

<BaseLayout title="首页" description="前端知识库 - 技术文档、项目案例、学习笔记">
  <section class="container py-24 lg:py-32">
    <div class="max-w-4xl">
      <h1 class="text-display text-primary mb-6 fade-in">
        DEV.JOURNAL
      </h1>
      <p class="text-xl text-secondary mb-8 fade-in" style="animation-delay: 0.1s">
        记录前端技术探索与实践，分享学习笔记与项目经验。
      </p>
      <div class="flex gap-4 fade-in" style="animation-delay: 0.2s">
        <a href="/articles" class="px-6 py-3 bg-[var(--color-primary)] text-[var(--color-bg)] font-semibold hover:opacity-80 transition-opacity">
          浏览文章
        </a>
        <a href="/about" class="px-6 py-3 border border-[var(--color-border)] font-semibold hover:bg-[var(--color-primary)] hover:text-[var(--color-bg)] transition-colors">
          关于我
        </a>
      </div>
    </div>
  </section>

  <section class="container pb-24">
    <h2 class="text-h2 text-primary mb-8">最新文章</h2>
    <div class="grid gap-6 md:grid-cols-2">
      {sortedArticles.map((article) => (
        <ArticleCard
          title={article.data.title}
          description={article.data.description}
          pubDate={article.data.pubDate}
          tags={article.data.tags}
          slug={article.slug}
        />
      ))}
    </div>

    {sortedArticles.length === 0 && (
      <div class="text-center py-12 text-muted">
        暂无文章，请先添加内容。
      </div>
    )}

    {sortedArticles.length > 0 && (
      <div class="mt-12 text-center">
        <a href="/articles" class="text-sm font-semibold text-primary hover:opacity-70 transition-opacity">
          查看全部文章 →
        </a>
      </div>
    )}
  </section>
</BaseLayout>
