---
import { formatDate } from '../utils/formatDate';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  tags: string[];
  slug: string;
  readingTime?: number;
}

const { title, description, pubDate, tags, slug, readingTime = 5 } = Astro.props;
---

<a
  href={`/articles/${slug}`}
  class="group block p-5 sm:p-6 md:p-7 bg-[var(--color-surface)] border border-[var(--color-border)] sm:border-l-4 sm:border-l-[var(--color-primary)] sm:hover:-translate-y-1 transition-all duration-200 rounded-lg sm:rounded-none"
>
  <div class="flex flex-wrap gap-2 mb-3">
    {tags.slice(0, 3).map((tag) => (
      <span class="text-[11px] sm:text-caption uppercase tracking-wider text-secondary font-medium">
        #{tag}
      </span>
    ))}
  </div>

  <h2 class="text-xl sm:text-lg lg:text-xl text-primary mb-3 font-bold leading-snug group-hover:opacity-70 transition-opacity">
    {title}
  </h2>

  <p class="text-sm sm:text-base text-secondary mb-4 line-clamp-2 sm:line-clamp-2 leading-relaxed">
    {description}
  </p>

  <div class="text-xs sm:text-caption text-muted flex items-center gap-2">
    <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
    <span class="w-1 h-1 rounded-full bg-muted"></span>
    <span>{readingTime} 分钟阅读</span>
  </div>
</a>
