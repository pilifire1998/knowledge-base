---
import { formatDate } from '../utils/formatDate';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  tags: string[];
  slug: string;
  readingTime?: number;
}

const { title, description, pubDate, tags, slug, readingTime = 5 } = Astro.props;
---

<a
  href={`/articles/${slug}`}
  class="group block p-4 sm:p-6 bg-[var(--color-surface)] border border-[var(--color-border)] sm:border-l-4 sm:border-l-[var(--color-primary)] sm:hover:-translate-y-1 transition-all duration-200"
>
  <div class="flex flex-wrap gap-1.5 sm:gap-2 mb-2 sm:mb-3">
    {tags.slice(0, 3).map((tag) => (
      <span class="text-[10px] sm:text-caption uppercase tracking-wider text-secondary">
        #{tag}
      </span>
    ))}
  </div>

  <h2 class="text-lg sm:text-xl text-primary mb-2 sm:mb-3 font-bold leading-snug group-hover:opacity-70 transition-opacity">
    {title}
  </h2>

  <p class="text-sm sm:text-base text-secondary mb-3 sm:mb-4 line-clamp-2 leading-relaxed">
    {description}
  </p>

  <div class="text-[11px] sm:text-caption text-muted">
    {formatDate(pubDate)} · {readingTime} 分钟阅读
  </div>
</a>
