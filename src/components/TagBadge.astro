---
interface Props {
  tag: string;
  count?: number;
  href?: string;
}

const { tag, count, href = `/tags/${tag}` } = Astro.props;
---

<a
  href={href}
  class="inline-flex items-center gap-2 px-3 py-1.5 bg-[var(--color-surface)] border border-[var(--color-border)] text-sm font-semibold text-primary hover:bg-[var(--color-primary)] hover:text-[var(--color-bg)] transition-colors"
>
  {tag}
  {count !== undefined && (
    <span class="text-xs text-muted">({count})</span>
  )}
</a>
